{
  "manifest_version": 3,
  "name": "CDP Bypass PoC",
  "version": "1.0",
  "permissions": ["debugger"],
  "host_permissions": ["<all_urls>"],
  "externally_connectable": {
    "matches": ["https://telojos11.github.io/*", "http://127.0.0.1:*/*", "http://localhost:*/*"]
  },
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Attach CDP" }
}
